{
  "version": 2,
  "builds": [
    {
      "src": "api/capi.js",
      "use": "@vercel/node"
    },
    {
      "src": "*.html",
      "use": "@vercel/static"
    },
    {
      "src": "assets/**",
      "use": "@vercel/static"
    },
    {
      "src": "team.png",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    { "src": "/api/capi", "dest": "/api/capi.js" },
    { "src": "/(.*)", "dest": "/$1" }
  ]
}
